.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 100rpx 24rpx 40rpx;
  background: #f4f6f8;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.picker {
  min-width: 320rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1f2933;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.render-button {
  margin: 0;
}

.compare-button {
  margin: 0;
}

.meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
  color: #52606d;
  font-size: 24rpx;
}

.canvas-scroll {
  width: 100%;
  height: 1200rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #d9e2ec;
  box-shadow: inset 0 0 0 2rpx rgba(148, 163, 184, 0.25);
}

.preview-image {
  display: block;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.12);
}

.preview-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #7b8794;
}

.compare-results {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.result-card {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.result-title {
  display: block;
  margin-bottom: 16rpx;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 600;
}

.result-image {
  display: block;
  width: 100%;
  background: #f8fafc;
}

.hidden-layer {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
}

.hidden-canvas {
  width: 1px;
  height: 1px;
}
